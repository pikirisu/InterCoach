# Server
PORT=3000
# Comma-separated browser origins allowed by CORS.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/inter-coach

# JWT
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-token-secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-token-secret
REFRESH_TOKEN_EXPIRY=10d

# AI provider
# Set AI_PROVIDER to either "openai" or "gemini".
# Only the selected provider's API key is required for local MVP analysis.
AI_PROVIDER=openai

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
